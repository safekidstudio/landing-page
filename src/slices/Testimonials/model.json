{
  "id": "testimonials",
  "type": "SharedSlice",
  "name": "Testimonials",
  "variations": [
    {
      "id": "default",
      "name": "Default",
      "description": "Default variation",
      "imageUrl": "",
      "docURL": "",
      "version": "initial",
      "primary": {
        "badge_text": {
          "type": "Text",
          "config": {
            "label": "Badge Text",
            "placeholder": "Loved by early testers"
          }
        },
        "heading": {
          "type": "StructuredText",
          "config": {
            "label": "Heading",
            "placeholder": "What Our Beta Testers & Tech Reviewers Are Saying",
            "single": "heading2"
          }
        },
        "stats_list": {
          "type": "Group",
          "config": {
            "label": "Stats List",
            "repeat": true,
            "fields": {
              "number": {
                "type": "Text",
                "config": {
                  "label": "Number",
                  "placeholder": "2,500+"
                }
              },
              "label": {
                "type": "Text",
                "config": {
                  "label": "Label",
                  "placeholder": "BETA USERS"
                }
              }
            }
          }
        }
      },
      "items": {
        "icon": {
          "type": "Select",
          "config": {
            "label": "Icon",
            "default_value": "user",
            "options": [
              "pencil",
              "file-text",
              "user",
              "globe",
              "quote"
            ]
          }
        },
        "author": {
          "type": "Text",
          "config": {
            "label": "Author",
            "placeholder": "u/selfhosted"
          }
        },
        "quote": {
          "type": "StructuredText",
          "config": {
            "label": "Quote",
            "placeholder": "I've been testing the Kibal beta...",
            "single": "paragraph"
          }
        },
        "link_label": {
          "type": "Text",
          "config": {
            "label": "Link Label",
            "placeholder": "Read more"
          }
        },
        "link": {
          "type": "Link",
          "config": {
            "label": "Link",
            "placeholder": "",
            "allowTargetBlank": true
          }
        }
      }
    }
  ],
  "description": "Reviews and Testimonials section with numerical stats and detailed cards representing user opinions."
}
