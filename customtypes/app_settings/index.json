{
  "id": "app_settings",
  "label": "App Settings",
  "repeatable": false,
  "json": {
    "Header": {
      "logo_image": {
        "type": "Image",
        "config": {
          "label": "Logo Image",
          "constraint": {},
          "thumbnails": []
        }
      },
      "navigation_items": {
        "type": "Group",
        "config": {
          "label": "Navigation Items",
          "repeat": true,
          "fields": {
            "label": {
              "type": "Text",
              "config": {
                "label": "Label",
                "placeholder": "Features"
              }
            },
            "link": {
              "type": "Link",
              "config": {
                "label": "Link",
                "allowTargetBlank": true
              }
            }
          }
        }
      },
      "login_button": {
        "type": "Link",
        "config": {
          "label": "Login Button",
          "placeholder": "",
          "allowTargetBlank": true,
          "allowText": true,
          "repeat": false
        }
      },
      "cta_button": {
        "type": "Link",
        "config": {
          "label": "CTA Button",
          "placeholder": "",
          "allowTargetBlank": true,
          "allowText": true,
          "repeat": false
        }
      }
    },
    "Footer": {
      "footer_logo_image": {
        "type": "Image",
        "config": {
          "label": "Footer Logo Image",
          "constraint": {},
          "thumbnails": []
        }
      },
      "footer_description": {
        "type": "StructuredText",
        "config": {
          "label": "Footer Description",
          "placeholder": "Privacy-first parental control application powered by on-device AI. Protect your children's digital world while keeping family data 100% private, secure, and under your control.",
          "single": "paragraph"
        }
      },
      "social_links": {
        "type": "Group",
        "config": {
          "label": "Social Links",
          "repeat": true,
          "fields": {
            "platform": {
              "type": "Select",
              "config": {
                "label": "Platform",
                "default_value": "facebook",
                "options": [
                  "facebook",
                  "twitter",
                  "linkedin",
                  "youtube",
                  "github",
                  "briefcase",
                  "instagram"
                ]
              }
            },
            "link": {
              "type": "Link",
              "config": {
                "label": "Link"
              }
            }
          }
        }
      },
      "footer_navigation_links": {
        "type": "Group",
        "config": {
          "label": "Footer Navigation Links",
          "repeat": true,
          "fields": {
            "column_title": {
              "type": "Text",
              "config": {
                "label": "Column Title (e.g. PRODUCT)",
                "placeholder": "PRODUCT"
              }
            },
            "links": {
              "type": "Link",
              "config": {
                "label": "Links",
                "placeholder": "",
                "allowTargetBlank": true,
                "allowText": true,
                "repeat": true
              }
            }
          }
        }
      },
      "copyright_text": {
        "type": "Text",
        "config": {
          "label": "Copyright Text",
          "placeholder": "© 2026 Kibal. All rights reserved. Privacy-first family protection."
        }
      },
      "bottom_texts": {
        "type": "Group",
        "config": {
          "label": "Bottom Texts (e.g. Terms of Service)",
          "repeat": true,
          "fields": {
            "label": {
              "type": "Text",
              "config": {
                "label": "Label",
                "placeholder": "Privacy Policy"
              }
            }
          }
        }
      }
    }
  },
  "status": true,
  "format": "custom"
}