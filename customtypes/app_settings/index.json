{
  "id": "app_settings",
  "label": "App Settings",
  "repeatable": false,
  "status": true,
  "format": "custom",
  "json": {
    "Header": {
      "logo_text": {
        "type": "Text",
        "config": {
          "label": "Logo Text",
          "placeholder": "Kibal"
        }
      },
      "logo_image": {
        "type": "Image",
        "config": {
          "label": "Logo Image",
          "constraint": {},
          "thumbnails": []
        }
      },
      "navigation_items": {
        "type": "Group",
        "config": {
          "label": "Navigation Items",
          "repeat": true,
          "fields": {
            "label": {
              "type": "Text",
              "config": {
                "label": "Label",
                "placeholder": "Features"
              }
            },
            "link": {
              "type": "Link",
              "config": {
                "label": "Link",
                "allowTargetBlank": true
              }
            },
            "badge_text": {
              "type": "Text",
              "config": {
                "label": "Badge Text (Optional)",
                "placeholder": "New"
              }
            }
          }
        }
      },
      "login_button_label": {
        "type": "Text",
        "config": {
          "label": "Login Button Label",
          "placeholder": "Login"
        }
      },
      "login_button_link": {
        "type": "Link",
        "config": {
          "label": "Login Button Link"
        }
      },
      "cta_button_label": {
        "type": "Text",
        "config": {
          "label": "CTA Button Label",
          "placeholder": "Get Started"
        }
      },
      "cta_button_link": {
        "type": "Link",
        "config": {
          "label": "CTA Button Link"
        }
      }
    },
    "Footer": {
      "footer_logo_text": {
        "type": "Text",
        "config": {
          "label": "Footer Logo Text",
          "placeholder": "Kibal"
        }
      },
      "footer_logo_image": {
        "type": "Image",
        "config": {
          "label": "Footer Logo Image",
          "constraint": {},
          "thumbnails": []
        }
      },
      "footer_description": {
        "type": "StructuredText",
        "config": {
          "label": "Footer Description",
          "single": "paragraph",
          "placeholder": "Privacy-first parental control application powered by on-device AI. Protect your children's digital world while keeping family data 100% private, secure, and under your control."
        }
      },
      "social_links": {
        "type": "Group",
        "config": {
          "label": "Social Links",
          "repeat": true,
          "fields": {
            "platform": {
              "type": "Select",
              "config": {
                "label": "Platform",
                "options": [
                  "facebook",
                  "twitter",
                  "linkedin",
                  "youtube",
                  "github",
                  "briefcase",
                  "instagram"
                ],
                "default_value": "facebook"
              }
            },
            "link": {
              "type": "Link",
              "config": {
                "label": "Link"
              }
            }
          }
        }
      },
      "footer_navigation_links": {
        "type": "Group",
        "config": {
          "label": "Footer Navigation Links",
          "repeat": true,
          "fields": {
            "column_title": {
              "type": "Text",
              "config": {
                "label": "Column Title (e.g. PRODUCT)",
                "placeholder": "PRODUCT"
              }
            },
            "label": {
              "type": "Text",
              "config": {
                "label": "Link Label",
                "placeholder": "Download"
              }
            },
            "link": {
              "type": "Link",
              "config": {
                "label": "Link"
              }
            }
          }
        }
      },
      "copyright_text": {
        "type": "Text",
        "config": {
          "label": "Copyright Text",
          "placeholder": "© 2026 Kibal. All rights reserved. Privacy-first family protection."
        }
      },
      "bottom_links": {
        "type": "Group",
        "config": {
          "label": "Bottom Links (e.g. Terms of Service)",
          "repeat": true,
          "fields": {
            "label": {
              "type": "Text",
              "config": {
                "label": "Label",
                "placeholder": "Privacy Policy"
              }
            },
            "link": {
              "type": "Link",
              "config": {
                "label": "Link"
              }
            }
          }
        }
      }
    }
  }
}
