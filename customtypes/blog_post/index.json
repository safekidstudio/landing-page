{
  "id": "blog_post",
  "label": "Blog Post",
  "repeatable": true,
  "json": {
    "Main": {
      "uid": {
        "type": "UID",
        "config": {
          "label": "UID"
        }
      },
      "category": {
        "type": "Text",
        "config": {
          "label": "Category / Tag",
          "placeholder": "DIGITAL HABITS"
        }
      },
      "read_time": {
        "type": "Text",
        "config": {
          "label": "Read Time",
          "placeholder": "12 MIN READ"
        }
      },
      "post_number": {
        "type": "Text",
        "config": {
          "label": "Post Number",
          "placeholder": "01"
        }
      },
      "featured_image": {
        "type": "Image",
        "config": {
          "label": "Featured Image / Cover Image",
          "constraint": {
            "width": 1200,
            "height": 750
          },
          "thumbnails": []
        }
      },
      "author_name": {
        "type": "Text",
        "config": {
          "label": "Author Name",
          "placeholder": "Kibal Official"
        }
      },
      "author_avatar": {
        "type": "Image",
        "config": {
          "label": "Author Avatar",
          "constraint": {
            "width": 200,
            "height": 200
          },
          "thumbnails": []
        }
      },
      "slices": {
        "type": "Slices",
        "fieldset": "Slice Zone",
        "config": {
          "choices": {
            "blog_content": {
              "type": "SharedSlice"
            }
          }
        }
      }
    },
    "SEO & Metadata": {
      "meta_title": {
        "type": "Text",
        "config": {
          "label": "Meta Title",
          "placeholder": "A title of the page used for social media and search engines"
        }
      },
      "meta_description": {
        "type": "Text",
        "config": {
          "label": "Meta Description",
          "placeholder": "A brief summary of the page"
        }
      },
      "meta_image": {
        "type": "Image",
        "config": {
          "label": "Meta Image",
          "constraint": {
            "width": 2400,
            "height": 1260
          },
          "thumbnails": []
        }
      }
    }
  },
  "status": true,
  "format": "page"
}
